# Ollama Mac-də işləyir. Gemma 3 1B yüngül modeldir.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:1b
N8N_ENCRYPTION_KEY=change-this-to-a-long-random-string

# Şəxsi kabinet girişi (sadə tək-istifadəçi qapısı — real sessiya təhlükəsizliyi deyil)
APP_USERNAME=admin
APP_PASSWORD=change-this-password

# Serverə (Digital Ocean və s.) çıxarmazdan əvvəl bunları dəyişin:
POSTGRES_PASSWORD=change-this-to-a-strong-password
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-too
